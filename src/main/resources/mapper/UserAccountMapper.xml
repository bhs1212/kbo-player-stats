<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.kbo.stats.mapper.UserAccountMapper">

    <resultMap id="UserAccountResultMap" type="com.kbo.stats.domain.UserAccount">
        <id     property="id"           column="id"/>
        <result property="username"     column="username"/>
        <result property="password"     column="password"/>
        <result property="favoriteTeam" column="favorite_team"/>
        <result property="role"         column="role"/>
        <result property="createdAt"    column="created_at"/>
    </resultMap>

    <!-- 사용자명으로 조회 -->
    <select id="findByUsername" parameterType="string"
            resultMap="UserAccountResultMap">
        SELECT id, username, password, favorite_team, role, created_at
        FROM user_account
        WHERE username = #{username}
        LIMIT 1
    </select>

    <!-- 사용자명 중복 여부 -->
    <select id="existsByUsername" parameterType="string" resultType="boolean">
        SELECT COUNT(*) > 0
        FROM user_account
        WHERE username = #{username}
    </select>

    <!-- 계정 등록 -->
    <insert id="insert" parameterType="com.kbo.stats.domain.UserAccount"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user_account (username, password, favorite_team, role)
        VALUES (#{username}, #{password}, #{favoriteTeam}, #{role})
    </insert>

    <!-- 응원 팀 변경 -->
    <update id="updateFavoriteTeam">
        UPDATE user_account
        SET favorite_team = #{favoriteTeam}
        WHERE username = #{username}
    </update>

</mapper>
